# Sumo Logic MCP Server Configuration
# Copy this file to .env and fill in your actual values

# Default instance configuration (used when no instance is specified)
SUMO_ACCESS_ID=your_access_id_here
SUMO_ACCESS_KEY=your_access_key_here
SUMO_ENDPOINT=https://api.sumologic.com
# Optional: Custom subdomain for your Sumo Logic instance (omit if using default service.xx.sumologic.com)
# SUMO_SUBDOMAIN=mycompany

# Additional instance configurations (optional)
# Format: SUMO_<INSTANCE_NAME>_ACCESS_ID, SUMO_<INSTANCE_NAME>_ACCESS_KEY, SUMO_<INSTANCE_NAME>_ENDPOINT, SUMO_<INSTANCE_NAME>_SUBDOMAIN

# Production instance (US2 region with custom subdomain)
# SUMO_PROD_ACCESS_ID=your_prod_access_id
# SUMO_PROD_ACCESS_KEY=your_prod_access_key
# SUMO_PROD_ENDPOINT=https://api.us2.sumologic.com
# SUMO_PROD_SUBDOMAIN=mycompany

# Staging instance (EU region with custom subdomain)
# SUMO_STAGING_ACCESS_ID=your_staging_access_id
# SUMO_STAGING_ACCESS_KEY=your_staging_access_key
# SUMO_STAGING_ENDPOINT=https://api.eu.sumologic.com
# SUMO_STAGING_SUBDOMAIN=mycompany-staging

# Development instance (AU region, no subdomain - uses default service.au.sumologic.com)
# SUMO_DEV_ACCESS_ID=your_dev_access_id
# SUMO_DEV_ACCESS_KEY=your_dev_access_key
# SUMO_DEV_ENDPOINT=https://api.au.sumologic.com

# Server Configuration
# Maximum number of results per query (default: 1000)
MAX_QUERY_LIMIT=1000

# Maximum search timeout in seconds (default: 300)
MAX_SEARCH_TIMEOUT=300

# Rate limiting: requests per minute per tool (default: 60)
RATE_LIMIT_PER_MINUTE=60

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable audit logging (default: true)
ENABLE_AUDIT_LOG=true
